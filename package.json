{
  "name": "opensyntax",
  "version": "0.2.0",
  "description": "OpenSyntax is a terminal-based AI chatbot CLI with provider setup inside the terminal UI.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itisuniqueofficial-gh/opensyntax.git"
  },
  "bugs": {
    "url": "https://github.com/itisuniqueofficial-gh/opensyntax/issues"
  },
  "homepage": "https://github.com/itisuniqueofficial-gh/opensyntax#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "opensyntax": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "node -e \"fs.rmSync('dist', {recursive: true, force: true})\"",
    "prepack": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "clipboardy": "^4.0.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.3.4",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.12",
    "ora": "^8.2.0",
    "react": "^18.3.1",
    "string-width": "^7.2.0",
    "strip-ansi": "^7.2.0",
    "undici": "^6.25.0",
    "wrap-ansi": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.3.5",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.5.4",
    "@types/react": "^18.3.5",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "semantic-release": "^24.2.9",
    "tsup": "^8.2.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
